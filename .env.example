# Puerto donde escucha el servidor (accesible via nginx en /preparaciones/)
PORT=3102

# Entorno Node
NODE_ENV=development

# SQL Server (SQL Server de OLAPS_MZ)
SQL_SERVER=SRVBI
SQL_DATABASE=OLAPS_MZ
SQL_USER=<USUARIO_SQL>
SQL_PASSWORD=<PASSWORD_SQL>
SQL_PORT=1433

# JWT Secret para validaciÃ³n de tokens de acceso
JWT_SECRET=change-in-production
