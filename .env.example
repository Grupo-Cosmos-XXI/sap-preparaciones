# ═══════════════════════════════════════════════════════════════
# Configuración de Preparaciones
# ═══════════════════════════════════════════════════════════════

# Puerto donde escucha el servidor
PORT=3002

# Entorno Node
NODE_ENV=development

# SQL Server (SQL Server de OLAPS_MZ)
SQL_SERVER=SRVBI
SQL_DATABASE=OLAPS_MZ
SQL_USER=<USUARIO_SQL>
SQL_PASSWORD=<PASSWORD_SQL>
SQL_PORT=1433

# JWT Secret para validación de tokens de acceso
JWT_SECRET=change-in-production
